# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/polymarket_bot
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5

# Polygon Network Configuration
POLYGON_RPC_URL=https://polygon-rpc.com
# For testing, use Mumbai testnet:
# POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polymarket API Configuration
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=your_polymarket_api_key_here

# Encryption Configuration
# This should be a secure random string (32 bytes hex encoded)
ENCRYPTION_KEY=your_secure_encryption_key_here

# Redis Configuration (for session management)
REDIS_URL=redis://localhost:6379/0

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=debug
PORT=8080

# Rate Limiting
RATE_LIMIT_PER_USER=60
RATE_LIMIT_WINDOW_MINUTES=1

# Trading Configuration
DEFAULT_SLIPPAGE_PERCENT=2.0
MAX_ORDER_SIZE_USDC=10000
MIN_ORDER_SIZE_USDC=1

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Gas Configuration (in Gwei)
DEFAULT_GAS_PRICE=30
MAX_GAS_PRICE=200

# Gnosis Safe Configuration
GNOSIS_SAFE_FACTORY_ADDRESS=0xa6B71E26C5e0845f74c812102Ca7114b6a896AB2
GNOSIS_SAFE_MASTER_COPY=0xd9Db270c1B5E3Bd161E8c8503c55cEABeE709552